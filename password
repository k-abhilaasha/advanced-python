a=input("Enter your Password:")
up=0
lw=0
sp=0
di=0
if len(a)>7:
  for i in a:
    if i.isupper():
      up=up+1
    elif i.islower():
      lw=lw+1
    elif i.isdigit():
      di+=1
    else:
      sp+=1
  if(up>0 and lw>0 and di>0 and sp>0):
    print("STRONG PASSWORD")
  else:
    print("WEAK PASSWORD")
else:
  print("PASSWORD IS INVALID DUE TO LESS CHARACTERS")
