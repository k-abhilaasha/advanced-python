class Graph:
  def __init__ (self,v):
    self.adj=[[] for i in range(v)]
  def add_edge(self,x,y):
    self.adj[x].append(y)
    self.adj[y].append(x)
  def display(self):
    for i in range(len(self.adj)):
      print("Node{}: ".format(i),end=" ")
      for j in self.adj[i]:
        print(j,end="-->")
      print()
a=Graph(6)
a.add_edge(0,2)
a.add_edge(0,3)
a.add_edge(1,4)
a.add_edge(1,3)
a.add_edge(3,2)
a.add_edge(3,3)
a.add_edge(5,1)
